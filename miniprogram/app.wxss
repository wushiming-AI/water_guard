/* ═══════════════════════════════════════════════════════════
   全局样式 — 深海科技主题 (Aqua Tech)
   ═══════════════════════════════════════════════════════════ */

page {
  background-color: #080f1e;
  color: #c8d8e8;
  font-family: -apple-system, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
}

/* ── 动画 ── */
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
@keyframes slideUp { from { opacity: 0; transform: translateY(30rpx); } to { opacity: 1; transform: translateY(0); } }
@keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }
@keyframes breathe { 0%, 100% { box-shadow: 0 0 8rpx rgba(52,152,219,0.3); } 50% { box-shadow: 0 0 20rpx rgba(52,152,219,0.6); } }
@keyframes ripple { 0% { transform: scale(0.8); opacity: 0.6; } 100% { transform: scale(2.4); opacity: 0; } }

/* ── 通用容器 ── */
.container {
  padding: 24rpx;
  min-height: 100vh;
  background: #080f1e;
}

/* ── 卡片 — 毛玻璃 ── */
.card {
  background: rgba(16, 30, 52, 0.75);
  border: 1rpx solid rgba(52, 152, 219, 0.18);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255,255,255,0.04);
}
.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
  padding-bottom: 18rpx;
  border-bottom: 1rpx solid rgba(52, 152, 219, 0.1);
}
.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #e8f0f8;
}

/* ── 按钮 ── */
.btn-primary {
  background: linear-gradient(135deg, #1565c0, #42a5f5);
  color: #fff;
  border: none;
  border-radius: 14rpx;
  padding: 22rpx 44rpx;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1;
  text-align: center;
  box-shadow: 0 6rpx 20rpx rgba(33, 150, 243, 0.35);
  transition: all 0.2s;
}
.btn-primary::after { border: none; }
.btn-primary[disabled] { opacity: 0.55; box-shadow: none; }

.btn-danger {
  background: rgba(231, 76, 60, 0.1);
  color: #ff6b6b;
  border: 1rpx solid rgba(231, 76, 60, 0.25);
  border-radius: 14rpx;
  padding: 16rpx 30rpx;
  font-size: 26rpx;
}
.btn-danger::after { border: none; }

/* ── 输入框 ── */
.input-field {
  width: 100%;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(52, 152, 219, 0.25);
  border-radius: 14rpx;
  padding: 22rpx 26rpx;
  color: #e0e8f0;
  font-size: 28rpx;
  box-sizing: border-box;
  transition: border-color 0.2s;
}

/* ── 分割线 ── */
.divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(52,152,219,0.15), transparent);
  margin: 16rpx 0;
}

/* ── 空状态 ── */
.empty-state {
  text-align: center;
  padding: 100rpx 40rpx;
  color: rgba(200, 216, 232, 0.3);
  font-size: 28rpx;
  animation: fadeIn 0.5s;
}

/* ── 加载状态 ── */
.loading-state {
  text-align: center;
  padding: 80rpx;
  color: rgba(200, 216, 232, 0.35);
  font-size: 28rpx;
}

/* ── 级别标签 ── */
.badge-urgent {
  background: linear-gradient(135deg, rgba(231,76,60,0.2), rgba(192,57,43,0.15));
  color: #ff6b6b;
  border: 1rpx solid rgba(231, 76, 60, 0.3);
  border-radius: 20rpx;
  padding: 4rpx 18rpx;
  font-size: 22rpx;
  font-weight: 600;
}
.badge-warning {
  background: linear-gradient(135deg, rgba(243,156,18,0.2), rgba(211,84,0,0.15));
  color: #ffc107;
  border: 1rpx solid rgba(243, 156, 18, 0.3);
  border-radius: 20rpx;
  padding: 4rpx 18rpx;
  font-size: 22rpx;
  font-weight: 600;
}
.badge-info {
  background: linear-gradient(135deg, rgba(52,152,219,0.2), rgba(33,150,243,0.15));
  color: #64b5f6;
  border: 1rpx solid rgba(52, 152, 219, 0.3);
  border-radius: 20rpx;
  padding: 4rpx 18rpx;
  font-size: 22rpx;
  font-weight: 600;
}
