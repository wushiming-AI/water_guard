/* ═══════════════════════════════════════════════════════════
   预警记录 — 时间线风格
   ═══════════════════════════════════════════════════════════ */

.page-container {
  padding: 20rpx 24rpx;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, #080f1e 0%, #0a1628 100%);
  min-height: 100vh;
}

/* ── 筛选栏 ── */
.filter-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
  background: rgba(12, 24, 48, 0.6);
  border: 1rpx solid rgba(52, 152, 219, 0.15);
  border-radius: 18rpx;
  padding: 24rpx 24rpx;
  margin-bottom: 24rpx;
  backdrop-filter: blur(8px);
}
.filter-label { font-size: 28rpx; color: rgba(180, 210, 240, 0.6); font-weight: 600; }

.date-picker {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(33, 150, 243, 0.08);
  border: 1rpx solid rgba(52, 152, 219, 0.25);
  border-radius: 14rpx;
  padding: 16rpx 26rpx;
}
.date-value { font-size: 28rpx; color: #64b5f6; font-weight: 600; }
.date-placeholder { font-size: 28rpx; color: rgba(180, 210, 240, 0.35); }
.picker-arrow { font-size: 20rpx; color: rgba(180, 210, 240, 0.35); }

.filter-reset {
  background: rgba(239, 83, 80, 0.08);
  border: 1rpx solid rgba(239, 83, 80, 0.2);
  border-radius: 14rpx;
  padding: 16rpx 24rpx;
  color: #ef5350;
  font-size: 26rpx;
  font-weight: 600;
}
.total-text {
  margin-left: auto;
  font-size: 26rpx;
  color: rgba(180, 210, 240, 0.35);
  font-weight: 500;
}

/* ── 列表 ── */
.alarm-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.alarm-card {
  display: flex;
  background: rgba(12, 24, 48, 0.55);
  border: 1rpx solid rgba(52, 152, 219, 0.12);
  border-radius: 18rpx;
  overflow: hidden;
  backdrop-filter: blur(6px);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.2);
  animation: slideUp 0.4s ease-out;
  transition: border-color 0.2s;
}
.alarm-card:active {
  border-color: rgba(52, 152, 219, 0.3);
}

.alarm-left-bar {
  width: 8rpx;
  flex-shrink: 0;
}
.alarm-left-bar.urgent {
  background: linear-gradient(180deg, #ef5350, #c62828);
  box-shadow: 2rpx 0 12rpx rgba(239, 83, 80, 0.3);
}
.alarm-left-bar.warning {
  background: linear-gradient(180deg, #ffc107, #ff8f00);
  box-shadow: 2rpx 0 12rpx rgba(255, 193, 7, 0.2);
}
.alarm-left-bar.info {
  background: linear-gradient(180deg, #42a5f5, #1565c0);
}

.alarm-body {
  flex: 1;
  padding: 22rpx 24rpx;
}
.alarm-row-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 14rpx;
}
.alarm-msg {
  font-size: 28rpx;
  color: #d0dce8;
  flex: 1;
  margin-right: 14rpx;
  line-height: 1.5;
  font-weight: 500;
}
.alarm-row-bottom {
  display: flex;
  gap: 24rpx;
  flex-wrap: wrap;
  align-items: center;
}
.alarm-meta {
  font-size: 23rpx;
  color: rgba(180, 210, 240, 0.35);
}
.alarm-time { margin-left: auto; }

.badge-urgent { background: linear-gradient(135deg, rgba(239,83,80,0.15), rgba(198,40,40,0.1)); color: #ef5350; border: 1rpx solid rgba(239,83,80,0.25); border-radius: 20rpx; padding: 4rpx 16rpx; font-size: 20rpx; white-space: nowrap; font-weight: 600; }
.badge-warning { background: linear-gradient(135deg, rgba(255,193,7,0.15), rgba(255,143,0,0.1)); color: #ffc107; border: 1rpx solid rgba(255,193,7,0.25); border-radius: 20rpx; padding: 4rpx 16rpx; font-size: 20rpx; white-space: nowrap; font-weight: 600; }
.badge-info { background: linear-gradient(135deg, rgba(66,165,245,0.15), rgba(21,101,192,0.1)); color: #64b5f6; border: 1rpx solid rgba(66,165,245,0.25); border-radius: 20rpx; padding: 4rpx 16rpx; font-size: 20rpx; white-space: nowrap; font-weight: 600; }

.load-more-tip {
  text-align: center;
  padding: 30rpx;
  font-size: 24rpx;
  color: rgba(180, 210, 240, 0.25);
}
.loading-state {
  text-align: center;
  padding: 100rpx;
  color: rgba(180, 210, 240, 0.3);
  font-size: 28rpx;
}
.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
  color: rgba(180, 210, 240, 0.22);
  font-size: 28rpx;
  animation: fadeIn 0.5s;
}
