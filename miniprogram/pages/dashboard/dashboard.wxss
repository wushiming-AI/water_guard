/* ═══════════════════════════════════════════════════════════
   监控大屏 — 科技仪表盘（多摄像头版）
   ═══════════════════════════════════════════════════════════ */

.page-container {
  padding: 20rpx 24rpx;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, #080f1e 0%, #0a1628 100%);
  min-height: 100vh;
}

/* ── WS 状态条 ── */
.ws-bar {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 14rpx 22rpx;
  border-radius: 14rpx;
  margin-bottom: 22rpx;
  font-size: 24rpx;
  font-weight: 500;
  backdrop-filter: blur(8px);
}
.ws-bar.connected {
  background: rgba(76, 175, 80, 0.08);
  border: 1rpx solid rgba(76, 175, 80, 0.2);
  color: #81c784;
}
.ws-bar.disconnected {
  background: rgba(255, 193, 7, 0.08);
  border: 1rpx solid rgba(255, 193, 7, 0.2);
  color: #ffd54f;
}
.ws-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: currentColor;
}
.ws-bar.connected .ws-dot {
  animation: pulse 2s ease-in-out infinite;
}

/* ── 统计网格 ── */
.stat-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  border-radius: 20rpx;
  padding: 26rpx 22rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  position: relative;
  overflow: hidden;
  backdrop-filter: blur(8px);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.25);
}
.stat-card::after {
  content: '';
  position: absolute;
  top: -30%;
  right: -20%;
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  opacity: 0.08;
}

.stat-card.blue {
  background: linear-gradient(145deg, rgba(21,101,192,0.25), rgba(33,150,243,0.12));
  border: 1rpx solid rgba(33, 150, 243, 0.2);
}
.stat-card.blue::after { background: #42a5f5; }
.stat-card.red {
  background: linear-gradient(145deg, rgba(198,40,40,0.25), rgba(239,83,80,0.12));
  border: 1rpx solid rgba(239, 83, 80, 0.2);
}
.stat-card.red::after { background: #ef5350; }
.stat-card.green {
  background: linear-gradient(145deg, rgba(27,94,32,0.25), rgba(76,175,80,0.12));
  border: 1rpx solid rgba(76, 175, 80, 0.2);
}
.stat-card.green::after { background: #66bb6a; }
.stat-card.purple {
  background: linear-gradient(145deg, rgba(106,27,154,0.25), rgba(171,71,188,0.12));
  border: 1rpx solid rgba(171, 71, 188, 0.2);
}
.stat-card.purple::after { background: #ab47bc; }

.stat-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}
.blue .stat-icon-wrap { background: rgba(33,150,243,0.15); }
.red .stat-icon-wrap { background: rgba(239,83,80,0.15); }
.green .stat-icon-wrap { background: rgba(76,175,80,0.15); }
.purple .stat-icon-wrap { background: rgba(171,71,188,0.15); }

.stat-body { display: flex; flex-direction: column; }
.stat-val {
  font-size: 44rpx;
  font-weight: 800;
  color: #f0f6fc;
  line-height: 1;
  font-variant-numeric: tabular-nums;
}
.stat-label {
  font-size: 22rpx;
  color: rgba(180, 210, 240, 0.45);
  margin-top: 8rpx;
  font-weight: 500;
}

/* ── 卡片 ── */
.card {
  background: rgba(12, 24, 48, 0.6);
  border: 1rpx solid rgba(52, 152, 219, 0.15);
  border-radius: 20rpx;
  padding: 26rpx;
  margin-bottom: 24rpx;
  backdrop-filter: blur(10px);
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.3);
}
.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}
.card-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #e8f0f8;
}

.live-badge {
  background: rgba(239, 83, 80, 0.12);
  border: 1rpx solid rgba(239, 83, 80, 0.3);
  border-radius: 24rpx;
  padding: 6rpx 18rpx;
  color: #ef5350;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  animation: breathe 2s ease-in-out infinite;
}
.alarm-count {
  font-size: 24rpx;
  color: rgba(180, 210, 240, 0.35);
  font-weight: 500;
}

/* ── 摄像头卡片头部右侧 ── */
.camera-header-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.refresh-btn {
  background: rgba(52, 152, 219, 0.12);
  border: 1rpx solid rgba(52, 152, 219, 0.25);
  border-radius: 24rpx;
  padding: 6rpx 18rpx;
  color: #64b5f6;
  font-size: 22rpx;
  font-weight: 500;
}

/* ═══════════════════════════════════════════════════════════
   多摄像头网格布局
   ═══════════════════════════════════════════════════════════ */

.camera-grid {
  display: grid;
  gap: 10rpx;
  padding: 4rpx;
}

.grid-1 { grid-template-columns: 1fr; }
.grid-2 { grid-template-columns: 1fr 1fr; }
.grid-3,
.grid-4 { grid-template-columns: 1fr 1fr; }
.grid-5,
.grid-6 { grid-template-columns: 1fr 1fr 1fr; }
.grid-7,
.grid-8,
.grid-9 { grid-template-columns: 1fr 1fr 1fr; }

/* ── 单个摄像头格子 ── */
.camera-cell {
  position: relative;
  aspect-ratio: 16/9;
  border-radius: 12rpx;
  overflow: hidden;
  background: #111;
  border: 1rpx solid rgba(52, 152, 219, 0.1);
  transition: border-color 0.2s;
}
.camera-cell:active {
  border-color: rgba(52, 152, 219, 0.5);
}

.camera-preview {
  width: 100%;
  height: 100%;
}

.camera-label {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 8rpx 14rpx;
  background: rgba(0, 0, 0, 0.65);
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 22rpx;
  color: #ccc;
}

.status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.status-dot.online {
  background: #55efc4;
  box-shadow: 0 0 8rpx rgba(85, 239, 196, 0.6);
}
.status-dot.offline {
  background: #636e72;
}

.offline-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #636e72;
  font-size: 26rpx;
}

/* ── 无摄像头 ── */
.no-camera {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
  color: rgba(180, 210, 240, 0.25);
  font-size: 26rpx;
  gap: 12rpx;
}
.no-camera-icon {
  font-size: 64rpx;
  opacity: 0.3;
}
.retry-link {
  margin-top: 12rpx;
  color: #64b5f6;
  font-size: 24rpx;
  padding: 10rpx 28rpx;
  border: 1rpx solid rgba(52, 152, 219, 0.3);
  border-radius: 24rpx;
}

/* ── 加载状态 ── */
.camera-loading {
  text-align: center;
  padding: 50rpx 0;
  color: rgba(180, 210, 240, 0.3);
  font-size: 26rpx;
}

/* ═══════════════════════════════════════════════════════════
   全屏模式
   ═══════════════════════════════════════════════════════════ */

.fullscreen-view {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #000;
  z-index: 999;
  display: flex;
  flex-direction: column;
}

.fullscreen-header {
  display: flex;
  align-items: center;
  padding: 20rpx 28rpx;
  background: rgba(0, 0, 0, 0.85);
  backdrop-filter: blur(10px);
  border-bottom: 1rpx solid rgba(52, 152, 219, 0.15);
  padding-top: calc(20rpx + env(safe-area-inset-top));
}

.back-btn {
  color: #3498db;
  font-size: 28rpx;
  margin-right: 28rpx;
  padding: 8rpx 0;
  font-weight: 500;
}

.fullscreen-title {
  flex: 1;
  color: #e8f0f8;
  font-size: 30rpx;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.fullscreen-header .status-dot {
  width: 16rpx;
  height: 16rpx;
}

.fullscreen-img-wrap {
  flex: 1;
  width: 100%;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.fullscreen-img {
  width: 100%;
  height: 100%;
}

.fullscreen-offline {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #636e72;
  font-size: 30rpx;
  gap: 16rpx;
}
.fullscreen-offline-icon {
  font-size: 80rpx;
  opacity: 0.4;
}

/* ── 预警条目 ── */
.alarm-item {
  display: flex;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(52, 152, 219, 0.06);
  animation: slideUp 0.4s ease-out;
}
.alarm-item:last-child { border-bottom: none; }

.alarm-left-bar {
  width: 6rpx;
  border-radius: 4rpx;
  margin-right: 18rpx;
  flex-shrink: 0;
}
.alarm-left-bar.urgent {
  background: linear-gradient(180deg, #ef5350, #c62828);
  box-shadow: 0 0 8rpx rgba(239, 83, 80, 0.4);
}
.alarm-left-bar.warning {
  background: linear-gradient(180deg, #ffc107, #ff8f00);
  box-shadow: 0 0 8rpx rgba(255, 193, 7, 0.3);
}
.alarm-left-bar.info {
  background: linear-gradient(180deg, #42a5f5, #1565c0);
}

.alarm-content { flex: 1; }
.alarm-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 10rpx;
}
.alarm-msg {
  font-size: 27rpx;
  color: #d0dce8;
  flex: 1;
  margin-right: 14rpx;
  line-height: 1.5;
}
.alarm-bottom {
  display: flex;
  gap: 24rpx;
  flex-wrap: wrap;
}
.alarm-meta {
  font-size: 22rpx;
  color: rgba(180, 210, 240, 0.35);
}

.badge-urgent { background: linear-gradient(135deg, rgba(239,83,80,0.15), rgba(198,40,40,0.1)); color: #ef5350; border: 1rpx solid rgba(239,83,80,0.25); border-radius: 20rpx; padding: 4rpx 16rpx; font-size: 20rpx; white-space: nowrap; font-weight: 600; }
.badge-warning { background: linear-gradient(135deg, rgba(255,193,7,0.15), rgba(255,143,0,0.1)); color: #ffc107; border: 1rpx solid rgba(255,193,7,0.25); border-radius: 20rpx; padding: 4rpx 16rpx; font-size: 20rpx; white-space: nowrap; font-weight: 600; }
.badge-info { background: linear-gradient(135deg, rgba(66,165,245,0.15), rgba(21,101,192,0.1)); color: #64b5f6; border: 1rpx solid rgba(66,165,245,0.25); border-radius: 20rpx; padding: 4rpx 16rpx; font-size: 20rpx; white-space: nowrap; font-weight: 600; }

.loading-state { text-align: center; padding: 50rpx; color: rgba(180,210,240,0.3); font-size: 26rpx; }
.empty-state { text-align: center; padding: 60rpx; color: rgba(180,210,240,0.25); font-size: 26rpx; animation: fadeIn 0.5s; }

/* ── 动画 ── */
@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}
@keyframes breathe {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.7; }
}
@keyframes slideUp {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
