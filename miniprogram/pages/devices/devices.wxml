<!-- pages/devices/devices.wxml -->
<view class="page-container">

  <!-- 顶部工具栏 -->
  <view class="toolbar">
    <text class="toolbar-title">设备列表（{{deviceList.length}} 台）</text>
    <view class="btn-add" bindtap="toggleAddForm">
      <text>{{showAddForm ? '✕ 取消' : '＋ 添加'}}</text>
    </view>
  </view>

  <!-- 添加设备表单 -->
  <view class="add-form" wx:if="{{showAddForm}}">
    <view class="form-title">添加新设备</view>
    <view class="form-item">
      <text class="form-label">设备名称 *</text>
      <input class="form-input" placeholder="如：光明湖3号摄像头" placeholder-style="color:rgba(200,216,232,0.3)"
        data-field="name" bindinput="onFormInput" value="{{form.name}}" />
    </view>
    <view class="form-item">
      <text class="form-label">设备 ID</text>
      <input class="form-input" placeholder="如：CAM-005" placeholder-style="color:rgba(200,216,232,0.3)"
        data-field="device_id" bindinput="onFormInput" value="{{form.device_id}}" />
    </view>
    <view class="form-item">
      <text class="form-label">安装位置</text>
      <input class="form-input" placeholder="如：光明湖西岸" placeholder-style="color:rgba(200,216,232,0.3)"
        data-field="location" bindinput="onFormInput" value="{{form.location}}" />
    </view>
    <view class="form-item">
      <text class="form-label">IP 地址</text>
      <input class="form-input" placeholder="如：192.168.1.105" placeholder-style="color:rgba(200,216,232,0.3)"
        data-field="ip_address" bindinput="onFormInput" value="{{form.ip_address}}" />
    </view>
    <view class="form-item">
      <text class="form-label">设备状态</text>
      <picker bindchange="onStatusChange" value="{{statusIndex}}" range="{{statusLabels}}">
        <view class="status-picker">
          <text>{{statusLabels[statusIndex]}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>
    <button class="save-btn" bindtap="saveDevice" disabled="{{saving}}" loading="{{saving}}">
      {{saving ? '保存中...' : '确认添加'}}
    </button>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading && deviceList.length === 0}}" class="loading-state">
    <text>⏳ 加载中...</text>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{deviceList.length === 0}}" class="empty-state">
    <text>📷 暂无设备，请点击「添加」</text>
  </view>

  <!-- 设备卡片 -->
  <view wx:else class="device-list">
    <view wx:for="{{deviceList}}" wx:key="id" class="device-card">
      <view class="device-card-top">
        <view class="device-icon-wrap">
          <text class="device-icon">📹</text>
        </view>
        <view class="device-status-wrap">
          <view class="status-dot {{item.status}}"></view>
          <text class="status-text {{item.status}}">{{item.statusLabel}}</text>
        </view>
      </view>
      <text class="device-name">{{item.name}}</text>
      <view class="device-info">
        <text class="info-row">🏷 ID：{{item.device_id || '--'}}</text>
        <text class="info-row">📍 位置：{{item.location || '--'}}</text>
        <text class="info-row">🌐 IP：{{item.ip_address || '--'}}</text>
        <text class="info-row">🕐 最近在线：{{item.lastOnlineShort}}</text>
      </view>
      <view class="device-actions">
        <view class="btn-toggle" bindtap="toggleStatus"
          data-id="{{item.id}}" data-status="{{item.status}}">
          <text>⇄ {{item.status === 'online' ? '设为离线' : '设为在线'}}</text>
        </view>
        <view class="btn-delete" bindtap="deleteDevice"
          data-id="{{item.id}}" data-name="{{item.name}}">
          <text>🗑 删除</text>
        </view>
      </view>
    </view>
  </view>

</view>
