/* ═══════════════════════════════════════════════════════════
   设备管理 — 卡片式布局
   ═══════════════════════════════════════════════════════════ */

.page-container {
  padding: 20rpx 24rpx;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, #080f1e 0%, #0a1628 100%);
  min-height: 100vh;
}

/* ── 工具栏 ── */
.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding: 0 4rpx;
}
.toolbar-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #e8f0f8;
}
.btn-add {
  background: linear-gradient(135deg, #1565c0, #42a5f5);
  border-radius: 14rpx;
  padding: 14rpx 32rpx;
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(33, 150, 243, 0.35);
}

/* ── 添加表单 ── */
.add-form {
  background: rgba(12, 24, 48, 0.65);
  border: 1rpx solid rgba(52, 152, 219, 0.2);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  backdrop-filter: blur(10px);
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.3);
  animation: slideUp 0.35s ease-out;
}
.form-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #e8f0f8;
  margin-bottom: 24rpx;
}
.form-item { margin-bottom: 24rpx; }
.form-label {
  font-size: 28rpx;
  color: rgba(180, 210, 240, 0.7);
  display: block;
  margin-bottom: 14rpx;
  font-weight: 600;
}
.form-input {
  width: 100%;
  height: 96rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(52, 152, 219, 0.2);
  border-radius: 16rpx;
  padding: 0 28rpx;
  color: #e0e8f0;
  font-size: 30rpx;
  box-sizing: border-box;
  transition: border-color 0.2s;
}
.form-input:focus {
  border-color: rgba(33, 150, 243, 0.5);
}

.status-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 96rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(52, 152, 219, 0.2);
  border-radius: 16rpx;
  padding: 0 28rpx;
  color: #64b5f6;
  font-size: 30rpx;
  box-sizing: border-box;
}
.picker-arrow { color: rgba(180, 210, 240, 0.3); font-size: 22rpx; }

.save-btn {
  width: 100%;
  height: 92rpx;
  background: linear-gradient(135deg, #1565c0, #42a5f5) !important;
  color: #fff !important;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 700;
  margin-top: 16rpx;
  line-height: 92rpx;
  box-shadow: 0 8rpx 28rpx rgba(33, 150, 243, 0.4);
}
.save-btn::after { border: none !important; }
.save-btn[disabled] { opacity: 0.55; }

/* ── 设备列表 ── */
.device-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.device-card {
  background: rgba(12, 24, 48, 0.55);
  border: 1rpx solid rgba(52, 152, 219, 0.12);
  border-radius: 20rpx;
  padding: 32rpx 28rpx;
  backdrop-filter: blur(8px);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.25);
  animation: slideUp 0.4s ease-out;
  transition: border-color 0.2s;
}
.device-card:active {
  border-color: rgba(52, 152, 219, 0.3);
}

.device-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}
.device-icon-wrap {
  width: 84rpx;
  height: 84rpx;
  border-radius: 22rpx;
  background: linear-gradient(145deg, #1565c0, #42a5f5);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(33, 150, 243, 0.3);
}
.device-icon { font-size: 42rpx; }

.device-status-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 10rpx 22rpx;
  border-radius: 22rpx;
}
.device-status-wrap.online {
  background: rgba(76, 175, 80, 0.08);
  border: 1rpx solid rgba(76, 175, 80, 0.2);
}
.device-status-wrap.offline {
  background: rgba(239, 83, 80, 0.08);
  border: 1rpx solid rgba(239, 83, 80, 0.2);
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}
.status-dot.online {
  background: #66bb6a;
  box-shadow: 0 0 10rpx rgba(76, 175, 80, 0.8);
  animation: pulse 2s ease-in-out infinite;
}
.status-dot.offline {
  background: #ef5350;
}

.status-text { font-size: 26rpx; font-weight: 600; }
.status-text.online { color: #81c784; }
.status-text.offline { color: #ef5350; }

.device-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #e8f0f8;
  margin-bottom: 20rpx;
}

.device-info {
  margin-bottom: 26rpx;
  padding: 20rpx 24rpx;
  background: rgba(0, 10, 25, 0.3);
  border-radius: 14rpx;
  border: 1rpx solid rgba(52, 152, 219, 0.06);
}
.info-row {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: rgba(180, 210, 240, 0.5);
  line-height: 2.4;
}

.device-actions {
  display: flex;
  gap: 18rpx;
}
.btn-toggle {
  flex: 1;
  text-align: center;
  padding: 22rpx 16rpx;
  background: rgba(33, 150, 243, 0.06);
  border: 1rpx solid rgba(52, 152, 219, 0.2);
  border-radius: 14rpx;
  color: #64b5f6;
  font-size: 26rpx;
  font-weight: 600;
  transition: background 0.2s;
}
.btn-toggle:active { background: rgba(33, 150, 243, 0.15); }
.btn-delete {
  flex: 1;
  text-align: center;
  padding: 22rpx 16rpx;
  background: rgba(239, 83, 80, 0.06);
  border: 1rpx solid rgba(239, 83, 80, 0.2);
  border-radius: 14rpx;
  color: #ef5350;
  font-size: 26rpx;
  font-weight: 600;
  transition: background 0.2s;
}
.btn-delete:active { background: rgba(239, 83, 80, 0.15); }

.loading-state { text-align: center; padding: 100rpx; color: rgba(180,210,240,0.3); font-size: 28rpx; }
.empty-state { text-align: center; padding: 120rpx 40rpx; color: rgba(180,210,240,0.22); font-size: 28rpx; animation: fadeIn 0.5s; }
