/* ═══════════════════════════════════════════════════════════
   登录页 — 深海沉浸风
   ═══════════════════════════════════════════════════════════ */

.login-page {
  min-height: 100vh;
  background: linear-gradient(170deg, #060d1a 0%, #0a1a30 40%, #0d2640 70%, #081422 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

/* ── 背景水波装饰 ── */
.bg-circle {
  position: fixed;
  border-radius: 50%;
  pointer-events: none;
}
.c1 {
  width: 700rpx; height: 700rpx;
  top: -250rpx; left: -200rpx;
  background: radial-gradient(circle, rgba(33,150,243,0.08), transparent 70%);
  animation: pulse 6s ease-in-out infinite;
}
.c2 {
  width: 600rpx; height: 600rpx;
  bottom: -180rpx; right: -180rpx;
  background: radial-gradient(circle, rgba(0,188,212,0.06), transparent 70%);
  animation: pulse 8s ease-in-out infinite 2s;
}
.c3 {
  width: 400rpx; height: 400rpx;
  top: 40%; left: 60%;
  background: radial-gradient(circle, rgba(52,152,219,0.05), transparent 70%);
  animation: pulse 7s ease-in-out infinite 4s;
}

/* ── 水波纹动画层 ── */
.wave-layer {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 200%;
  height: 300rpx;
  pointer-events: none;
  opacity: 0.06;
}
.wave-path {
  animation: waveMove 12s linear infinite;
}
@keyframes waveMove {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

/* ── 登录卡片 ── */
.login-box {
  width: 680rpx;
  background: rgba(12, 24, 48, 0.7);
  border: 1rpx solid rgba(52, 152, 219, 0.2);
  border-radius: 28rpx;
  padding: 56rpx 44rpx 44rpx;
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  box-shadow:
    0 12rpx 48rpx rgba(0, 0, 0, 0.5),
    0 0 80rpx rgba(33, 150, 243, 0.08),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
  position: relative;
  z-index: 1;
  animation: slideUp 0.6s ease-out;
}

/* ── Logo ── */
.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}
.logo-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 32rpx;
  background: linear-gradient(145deg, #1565c0, #42a5f5);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  box-shadow: 0 0 50rpx rgba(33, 150, 243, 0.45), 0 8rpx 24rpx rgba(0,0,0,0.3);
  animation: breathe 3s ease-in-out infinite;
}
.icon-text { font-size: 56rpx; }
.logo-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #f0f6fc;
  letter-spacing: 2rpx;
}
.logo-sub {
  font-size: 20rpx;
  color: rgba(160, 190, 220, 0.4);
  margin-top: 8rpx;
  letter-spacing: 1rpx;
}

/* ─── 服务器地址配置 ─── */
.server-section { margin-bottom: 28rpx; }

.server-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 22rpx;
  background: rgba(33, 150, 243, 0.06);
  border: 1rpx solid rgba(52, 152, 219, 0.18);
  border-radius: 12rpx;
}
.server-toggle-text {
  font-size: 24rpx;
  color: rgba(180, 210, 240, 0.7);
}
.server-toggle-arrow {
  font-size: 20rpx;
  color: rgba(180, 210, 240, 0.35);
}

.server-detail {
  margin-top: 14rpx;
  padding: 18rpx;
  background: rgba(0, 10, 25, 0.4);
  border: 1rpx solid rgba(52, 152, 219, 0.1);
  border-radius: 12rpx;
  animation: slideUp 0.3s ease-out;
}

.server-input-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.server-input {
  flex: 1;
  height: 70rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(52, 152, 219, 0.25);
  border-radius: 10rpx;
  padding: 0 18rpx;
  color: #e0e8f0;
  font-size: 24rpx;
}

.test-btn {
  background: linear-gradient(135deg, rgba(33,150,243,0.2), rgba(33,150,243,0.35)) !important;
  color: #90caf9 !important;
  border: 1rpx solid rgba(52, 152, 219, 0.3) !important;
  border-radius: 10rpx !important;
  font-size: 24rpx !important;
  padding: 0 24rpx !important;
  height: 70rpx !important;
  line-height: 70rpx !important;
  white-space: nowrap !important;
  font-weight: 600 !important;
}
.test-btn::after { border: none !important; }

.test-result {
  font-size: 22rpx;
  padding: 10rpx 0;
  color: rgba(200, 216, 232, 0.4);
  font-weight: 500;
}
.test-result.ok { color: #4caf50; }
.test-result.fail { color: #ef5350; }

.server-tips {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  margin-top: 10rpx;
}
.server-tips text {
  font-size: 20rpx;
  color: rgba(180, 210, 240, 0.25);
  line-height: 1.6;
}

/* ─── 表单 ─── */
.form-area { margin-bottom: 28rpx; }

.input-wrap {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(52, 152, 219, 0.2);
  border-radius: 16rpx;
  padding: 0 26rpx;
  height: 96rpx;
  transition: border-color 0.2s, box-shadow 0.2s;
}
.input-wrap:focus-within {
  border-color: rgba(33, 150, 243, 0.5);
  box-shadow: 0 0 16rpx rgba(33, 150, 243, 0.15);
}
.input-icon { font-size: 36rpx; margin-right: 18rpx; }
.input-inner {
  flex: 1;
  color: #e8f0f8;
  font-size: 30rpx;
  background: transparent;
}

.remember-row {
  display: flex;
  align-items: center;
  margin: 24rpx 0 12rpx;
}
.remember-text { font-size: 26rpx; color: rgba(180, 210, 240, 0.45); }

.error-msg {
  background: rgba(231, 76, 60, 0.08);
  border: 1rpx solid rgba(231, 76, 60, 0.2);
  border-radius: 12rpx;
  padding: 18rpx 22rpx;
  color: #ff6b6b;
  font-size: 24rpx;
  margin-bottom: 18rpx;
  animation: slideUp 0.3s ease-out;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #1565c0, #42a5f5) !important;
  color: #fff !important;
  border-radius: 16rpx;
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 6rpx;
  margin-top: 20rpx;
  box-shadow: 0 10rpx 32rpx rgba(33, 150, 243, 0.4);
}
.login-btn::after { border: none !important; }
.login-btn[disabled] { opacity: 0.55; box-shadow: none; }

.hint-text {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: rgba(160, 190, 220, 0.2);
  margin-top: 4rpx;
}
