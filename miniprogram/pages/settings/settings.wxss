/* ═══════════════════════════════════════════════════════════
   系统设置 — 分组卡片
   ═══════════════════════════════════════════════════════════ */

.page-container {
  padding: 20rpx 24rpx;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, #080f1e 0%, #0a1628 100%);
  min-height: 100vh;
}

/* ── 用户卡片 ── */
.user-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: linear-gradient(145deg, rgba(21,101,192,0.15), rgba(33,150,243,0.08));
  border: 1rpx solid rgba(52, 152, 219, 0.2);
  border-radius: 22rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 24rpx;
  backdrop-filter: blur(10px);
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.3);
  position: relative;
  overflow: hidden;
}
.user-card::after {
  content: '';
  position: absolute;
  top: -30%;
  right: -10%;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: rgba(33, 150, 243, 0.06);
}
.user-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #1565c0, #42a5f5);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  box-shadow: 0 4rpx 16rpx rgba(33, 150, 243, 0.35);
  flex-shrink: 0;
}
.user-phone { font-size: 32rpx; font-weight: 700; color: #e8f0f8; display: block; }
.user-role {
  font-size: 24rpx;
  color: rgba(180, 210, 240, 0.4);
  display: block;
  margin-top: 6rpx;
  font-weight: 500;
}

/* ── 设置区 ── */
.section-card {
  background: rgba(12, 24, 48, 0.55);
  border: 1rpx solid rgba(52, 152, 219, 0.12);
  border-radius: 20rpx;
  padding: 28rpx 28rpx;
  margin-bottom: 20rpx;
  backdrop-filter: blur(8px);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.25);
  animation: slideUp 0.4s ease-out;
}
.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: rgba(180, 210, 240, 0.6);
  margin-bottom: 20rpx;
  letter-spacing: 1rpx;
  text-transform: uppercase;
}
.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 0;
}
.setting-left { flex: 1; margin-right: 28rpx; }
.setting-label { font-size: 30rpx; color: #d0dce8; display: block; font-weight: 600; }
.setting-desc { font-size: 24rpx; color: rgba(180, 210, 240, 0.4); display: block; margin-top: 6rpx; }
.divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(52,152,219,0.1), transparent);
  margin: 6rpx 0;
}

/* ── 服务地址输入 ── */
.url-input {
  width: 100%;
  height: 96rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(52, 152, 219, 0.2);
  border-radius: 16rpx;
  padding: 0 28rpx;
  color: #64b5f6;
  font-size: 30rpx;
  box-sizing: border-box;
  margin-top: 14rpx;
  transition: border-color 0.2s;
}
.url-input:focus {
  border-color: rgba(33, 150, 243, 0.5);
}

/* ── picker ── */
.picker-btn {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(33, 150, 243, 0.08);
  border: 1rpx solid rgba(52, 152, 219, 0.2);
  border-radius: 14rpx;
  padding: 18rpx 28rpx;
  color: #64b5f6;
  font-size: 28rpx;
  font-weight: 600;
}
.arrow { font-size: 20rpx; color: rgba(180, 210, 240, 0.3); }
.arrow-right { font-size: 24rpx; color: rgba(180, 210, 240, 0.3); }

/* ── 保存按钮 ── */
.save-btn {
  width: 100%;
  height: 92rpx;
  background: linear-gradient(135deg, #1565c0, #42a5f5) !important;
  color: #fff !important;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 18rpx;
  line-height: 92rpx;
  box-shadow: 0 8rpx 28rpx rgba(33, 150, 243, 0.4);
  letter-spacing: 2rpx;
}
.save-btn::after { border: none !important; }
.save-btn[disabled] { opacity: 0.55; box-shadow: none; }

/* ── 密码表单 ── */
.pwd-form {
  margin-top: 16rpx;
  animation: slideUp 0.35s ease-out;
}
.pwd-input-wrap { margin: 24rpx 0; }
.pwd-label {
  font-size: 28rpx;
  color: rgba(180, 210, 240, 0.7);
  display: block;
  margin-bottom: 14rpx;
  font-weight: 600;
}
.pwd-input {
  width: 100%;
  height: 96rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(52, 152, 219, 0.2);
  border-radius: 16rpx;
  padding: 0 28rpx;
  color: #e0e8f0;
  font-size: 30rpx;
  box-sizing: border-box;
  transition: border-color 0.2s;
}
.pwd-input:focus {
  border-color: rgba(33, 150, 243, 0.5);
}
.pwd-save-btn {
  width: 100%;
  height: 92rpx;
  background: linear-gradient(135deg, #1565c0, #42a5f5) !important;
  color: #fff !important;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 700;
  margin-top: 24rpx;
  line-height: 92rpx;
  box-shadow: 0 8rpx 28rpx rgba(33, 150, 243, 0.4);
}
.pwd-save-btn::after { border: none !important; }
.pwd-save-btn[disabled] { opacity: 0.55; }

/* ── 退出按钮 ── */
.logout-btn {
  width: 100%;
  height: 92rpx;
  background: rgba(239, 83, 80, 0.06) !important;
  border: 1rpx solid rgba(239, 83, 80, 0.2) !important;
  border-radius: 16rpx;
  color: #ef5350 !important;
  font-size: 30rpx;
  font-weight: 700;
  margin-top: 12rpx;
  line-height: 92rpx;
  letter-spacing: 2rpx;
}
.logout-btn::after { border: none !important; }
